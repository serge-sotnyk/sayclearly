# Local dev convenience: copying this file opts into Gemini Flash Lite.
# Product/runtime defaults remain gemini-3-flash-preview in application code.
GEMINI_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
SAYCLEARLY_DEFAULT_TEXT_MODEL=gemini-3.1-flash-lite-preview
SAYCLEARLY_DEFAULT_ANALYSIS_MODEL=gemini-3.1-flash-lite-preview
